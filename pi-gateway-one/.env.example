# Azure IoT Hub
IOTHUB_DEVICE_CONNECTION_STRING=HostName=<hub>.azure-devices.net;DeviceId=<device>;SharedAccessKey=<key>

# MQTT Broker that sensor boards publish to
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=sensors
MQTT_USERNAME=
MQTT_PASSWORD=

# Edge computing
SEND_INTERVAL=10         # seconds between batched sends to Azure IoT Hub
EDGE_WINDOW_SIZE=5       # rolling window size for moving average / anomaly detection
Z_SCORE_THRESHOLD=2.5    # z-score threshold for anomaly flagging
